DE_PIPELINE_PROJECT_ROOT=.
DE_PIPELINE_STORAGE_ROOT=./storage
DE_PIPELINE_DATA_LAKE_ROOT=./storage/data_lake
DE_PIPELINE_CHECKPOINT_ROOT=./storage/checkpoints
DE_PIPELINE_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
DE_PIPELINE_KAFKA_TOPIC=user_events_v1
DE_PIPELINE_KAFKA_CLIENT_ID=de-pipeline
DE_PIPELINE_GENERATOR_INTERVAL_SECONDS=1.0
DE_PIPELINE_GENERATOR_BATCH_SIZE=5
DE_PIPELINE_GENERATOR_SEED=42
DE_PIPELINE_WATERMARK_MINUTES=15
DE_PIPELINE_WAREHOUSE_HOST=localhost
DE_PIPELINE_WAREHOUSE_PORT=5432
DE_PIPELINE_WAREHOUSE_DATABASE=analytics
DE_PIPELINE_WAREHOUSE_USER=pipeline
DE_PIPELINE_WAREHOUSE_PASSWORD=pipeline
DE_PIPELINE_WAREHOUSE_STAGING_SCHEMA=staging
DE_PIPELINE_WAREHOUSE_ANALYTICS_SCHEMA=analytics
DE_PIPELINE_WAREHOUSE_LOAD_TO_POSTGRES=true
DE_PIPELINE_PRODUCT_SEED_PATH=./infra/postgres/products_seed.csv
DE_PIPELINE_SPARK_MASTER=local[*]
DE_PIPELINE_SPARK_PACKAGES=org.postgresql:postgresql:42.7.3
DE_PIPELINE_AIRFLOW_SCHEDULE=0 2 * * *

